{
  "name": "reframer",
  "version": "1.0.0",
  "description": "An elegant CLI tool for Rational Emotive Behavior Therapy (REBT) journaling with AI feedback and gamification",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "reframer": "./dist/index.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "dev": "NODE_OPTIONS='--disable-warning=DEP0040' tsx src/index.ts",
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "generate-audio": "tsx scripts/generate-audio.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["rebt", "journaling", "cbt", "therapy", "cli", "mental-health", "stoic"],
  "author": "Ayon Bhattacharya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-eigengrau/reframer.git"
  },
  "homepage": "https://github.com/the-eigengrau/reframer#readme",
  "bugs": {
    "url": "https://github.com/the-eigengrau/reframer/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@inquirer/prompts": "^7.0.0",
    "better-sqlite3": "^11.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "chalk-animation": "^2.0.3",
    "figlet": "^1.8.0",
    "gradient-string": "^3.0.0",
    "ora": "^8.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/chalk-animation": "^1.6.3",
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
